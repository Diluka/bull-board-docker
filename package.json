{
  "name": "bull-board-docker",
  "version": "6.7.0",
  "type": "module",
  "main": "src/index.ts",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "deno run -A src/index.ts",
    "dev": "deno run -A --watch --env-file src/index.ts",
    "pretest": "npm run test:stack:up",
    "test": "docker compose -f docker-compose.test.yml run --rm sut",
    "posttest": "npm run test:stack:down",
    "test:stack:up": "docker compose -f docker-compose.test.yml up -d --build bull-board",
    "test:stack:down": "docker compose -f docker-compose.test.yml down --rmi local"
  },
  "repository": "https://github.com/Diluka/bull-board-docker",
  "dependencies": {
    "@bull-board/api": "^8.1.2",
    "@bull-board/express": "^8.1.2",
    "bull": "^4.16.5",
    "bullmq": "^5.80.9",
    "connect-ensure-login": "^0.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ioredis": "~5.11.1",
    "morgan": "^1.11.0",
    "passport": "^0.7.0",
    "passport-http": "^0.3.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@types/connect-ensure-login": "^0.1.9",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/passport": "^1.0.17",
    "@types/passport-http": "^0.3.11",
    "@types/passport-local": "^1.0.38"
  }
}
